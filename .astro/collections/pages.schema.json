{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "wpId": {
      "type": "number"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "parent": {
      "type": "string"
    },
    "description": {
      "default": "",
      "type": "string"
    },
    "lang": {
      "default": "mixed",
      "type": "string",
      "enum": [
        "zh-Hant",
        "en",
        "mixed"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "wpId",
    "title",
    "slug"
  ]
}