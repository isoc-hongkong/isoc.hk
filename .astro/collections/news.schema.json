{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "wpId": {
      "type": "number"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "originalSlug": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "modified": {
      "type": "string",
      "format": "date-time"
    },
    "excerpt": {
      "default": "",
      "type": "string"
    },
    "description": {
      "default": "",
      "type": "string"
    },
    "categories": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featuredImage": {
      "type": "string"
    },
    "featuredImageAlt": {
      "type": "string"
    },
    "lang": {
      "default": "mixed",
      "type": "string",
      "enum": [
        "zh-Hant",
        "en",
        "mixed"
      ]
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "wpId",
    "title",
    "slug",
    "date"
  ]
}