---
import { sanityClient } from 'sanity:client';
import { PortableText } from 'astro-portabletext';
import PageLayout from '../layouts/PageLayout.astro';
import StripeCheckoutButton from '../components/StripeCheckoutButton.astro';
import { ALL_PAGES_QUERY } from '../utils/sanity';
import PortableTextImage from '../components/PortableTextImage.astro';

export async function getStaticPaths() {
  const pages = await sanityClient.fetch(ALL_PAGES_QUERY);
  return pages.map((page: any) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const { stripePlan } = page;
const lang = page.lang === 'zh-Hant' ? 'zh-Hant' : 'en';
---

<PageLayout
  title={page.title}
  description={page.description}
  lang={lang}
>
  <div class="page-banner">
    <div class="container">
      <h1>{page.title}</h1>
      <div class="breadcrumb">
        {page.parent
          ? <><a href="/">Home</a> / <a href={`/${page.parent.slug}/`}>{page.parent.title}</a> / {page.title}</>
          : <><a href="/">Home</a> / {page.title}</>
        }
      </div>
    </div>
  </div>

  <div class="container page-content">
    <div class="prose">
      <PortableText value={page.body} components={{ type: { image: PortableTextImage } }} />
      {stripePlan && (
        <StripeCheckoutButton
          planId={stripePlan.planId}
          label={stripePlan.label}
          successUrl={stripePlan.successUrl}
          cancelUrl={stripePlan.cancelUrl}
        />
      )}
    </div>
  </div>
</PageLayout>

<style>
  .page-content {
    padding: 2rem 1.25rem 3rem;
    max-width: 860px;
  }
</style>
