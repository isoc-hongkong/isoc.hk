---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('news', ({ data }) => !data.draft);

  // Collect all unique category slugs
  const categorySet = new Set<string>();
  allPosts.forEach(post => post.data.categories.forEach(c => categorySet.add(c)));

  return [...categorySet].map(slug => {
    const posts = allPosts
      .filter(p => p.data.categories.includes(slug))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    return { params: { slug }, props: { slug, posts } };
  });
}

const { slug, posts } = Astro.props;
const label = slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

function formatDate(d: Date) {
  return d.toLocaleDateString('en-HK', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<PageLayout title={label} description={`Posts in ${label} — Internet Society Hong Kong`}>
  <div class="page-banner">
    <div class="container">
      <h1>{label}</h1>
      <div class="breadcrumb"><a href="/">Home</a> / <a href="/category/news/">Categories</a> / {label}</div>
    </div>
  </div>

  <div class="container" style="padding-bottom: 3rem;">
    {posts.length === 0 ? (
      <p>No posts in this category yet.</p>
    ) : (
      <div class="post-grid">
        {posts.map((post) => (
          <article class="post-card">
            {post.data.featuredImage && (
              <div class="post-card__image">
                <img src={post.data.featuredImage} alt={post.data.featuredImageAlt || post.data.title} loading="lazy" />
              </div>
            )}
            <div class="post-card__body">
              <div class="post-card__meta">{formatDate(post.data.date)}</div>
              <h2 class="post-card__title">
                <a href={`/news/${post.data.slug}/`}>{post.data.title}</a>
              </h2>
              {post.data.excerpt && (
                <p class="post-card__excerpt">{post.data.excerpt.slice(0, 120)}{post.data.excerpt.length > 120 ? '…' : ''}</p>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</PageLayout>
