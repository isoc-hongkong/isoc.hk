---
import { sanityClient } from 'sanity:client';
import PageLayout from '../../../layouts/PageLayout.astro';
import { urlFor, ALL_CATEGORIES_QUERY } from '../../../utils/sanity';

export async function getStaticPaths() {
  const categories = await sanityClient.fetch(ALL_CATEGORIES_QUERY);
  return categories.map((cat: any) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-HK', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<PageLayout title={category.title} description={`Posts in ${category.title} — Internet Society Hong Kong`}>
  <div class="page-banner">
    <div class="container">
      <h1>{category.title}</h1>
      <div class="breadcrumb"><a href="/">Home</a> / <a href="/category/news/">Categories</a> / {category.title}</div>
    </div>
  </div>

  <div class="container" style="padding-bottom: 3rem;">
    {category.posts.length === 0 ? (
      <p>No posts in this category yet.</p>
    ) : (
      <div class="post-grid">
        {category.posts.map((post: any) => (
          <article class="post-card">
            {post.featuredImage?.asset && (
              <div class="post-card__image">
                <img
                  src={urlFor(post.featuredImage).width(600).url()}
                  alt={post.featuredImage.alt || post.title}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <div class="post-card__body">
              <div class="post-card__meta">{formatDate(post.publishedAt)}</div>
              <h2 class="post-card__title">
                <a href={`/news/${post.slug}/`}>{post.title}</a>
              </h2>
              {post.excerpt && (
                <p class="post-card__excerpt">{post.excerpt.slice(0, 120)}{post.excerpt.length > 120 ? '…' : ''}</p>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</PageLayout>
