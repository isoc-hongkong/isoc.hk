---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Picture from '../components/Picture.astro';
import '../styles/global.css';

const allPosts = await getCollection('news', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const rendered = await Promise.all(
  recentPosts.map(async (post) => {
    const { Content } = await render(post);
    return { post, Content };
  })
);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-HK', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="" lang="zh-Hant">
  <div class="hero-band">
    <Header transparent />
    <div class="hero container">
      <h1 class="hero-title">Internet Society Hong Kong</h1>
      <p class="hero-subtitle">Promoting the open development, evolution, and use of the Internet for everyone in Hong Kong and beyond.</p>
      <div class="hero-actions">
        <a href="/about/" class="btn btn--primary">About Us</a>
        <a href="/be-our-members/" class="btn btn--outline">Join Us</a>
      </div>
    </div>
  </div>

  <main class="site-content">
    <div class="container home-feed-section">
      <div class="home-feed">
        {rendered.map(({ post, Content }) => (
          <article class="home-post">
            {post.data.featuredImage && (
              <div class="home-post__image">
                <a href={`/news/${post.data.slug}/`}>
                  <Picture src={post.data.featuredImage} alt={post.data.featuredImageAlt || post.data.title} loading="lazy" />
                </a>
              </div>
            )}
            <header class="home-post__header">
              <div class="home-post__meta">
                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                {post.data.categories.slice(0, 2).map(cat => (
                  <a href={`/category/${cat}/`} class="cat-tag">{cat.replace(/-/g, ' ')}</a>
                ))}
              </div>
              <h2 class="home-post__title">
                <a href={`/news/${post.data.slug}/`}>{post.data.title}</a>
              </h2>
            </header>
            <div class="prose">
              <Content />
            </div>
          </article>
        ))}
      </div>
      <div class="posts-more">
        <a href="/category/news/" class="btn btn--primary">All News</a>
        <a href="/category/events/" class="btn btn--outline">All Events</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Unified header + hero band with the deep blue background image */
  .hero-band {
    background-image: url('/images/uploads/2018/02/header-isoc.webp');
    background-size: cover;
    background-position: center top;
  }

  .hero {
    text-align: center;
    padding: 3.5rem 1.25rem 4rem;
  }
  .hero-title {
    font-size: 2.4rem;
    color: #fff;
    margin-bottom: 0.75rem;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  .hero-subtitle {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    max-width: 600px;
    margin: 0 auto 1.75rem;
    text-shadow: 0 1px 3px rgba(0,0,0,0.35);
  }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius);
    font-size: 0.95rem;
    font-weight: 600;
    transition: background-color 0.15s, border-color 0.15s;
    text-decoration: none;
  }
  .btn--primary { background: var(--color-teal); color: white; }
  .btn--primary:hover { background: var(--color-teal-dark); text-decoration: none; }
  .btn--outline { border: 2px solid rgba(255,255,255,0.85); color: #fff; }
  .btn--outline:hover { background: rgba(255,255,255,0.15); text-decoration: none; }

  .home-feed-section { padding-bottom: 3rem; }

  .home-feed {
    display: flex;
    flex-direction: column;
  }

  .home-post {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .home-post:first-child { padding-top: 2.5rem; }
  .home-post:last-child { border-bottom: none; }

  .home-post__image {
    margin-bottom: 1.25rem;
    border-radius: var(--radius);
    overflow: hidden;
  }
  .home-post__image img { width: 100%; height: auto; }
  .home-post__image a { display: block; }

  .home-post__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .home-post__title {
    font-size: 1.6rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .home-post__title a { color: var(--color-navy); text-decoration: none; }
  .home-post__title a:hover { color: var(--color-teal); }

  .home-post__header { margin-bottom: 1rem; }

  .posts-more {
    text-align: center;
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* "All News" btn reuse on white bg */
  .posts-more .btn--outline {
    border-color: var(--color-navy);
    color: var(--color-navy);
  }
  .posts-more .btn--outline:hover {
    background: var(--color-navy);
    color: white;
  }
</style>
