---
import { sanityClient } from 'sanity:client';
import { PortableText } from 'astro-portabletext';
import PageLayout from '../../layouts/PageLayout.astro';
import { urlFor, ALL_POSTS_WITH_BODY_QUERY } from '../../utils/sanity';
import PortableTextImage from '../../components/PortableTextImage.astro';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(ALL_POSTS_WITH_BODY_QUERY);
  return posts.map((post: any) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-HK', { year: 'numeric', month: 'long', day: 'numeric' });
}

const lang = post.lang === 'zh-Hant' ? 'zh-Hant' : post.lang === 'en' ? 'en' : 'zh-Hant';
const featuredImageUrl = post.featuredImage?.asset
  ? urlFor(post.featuredImage).width(1200).url()
  : undefined;
---

<PageLayout
  title={post.title}
  description={post.description || post.excerpt}
  image={featuredImageUrl}
  lang={lang}
>
  <div class="page-banner">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> /
        {post.categories[0] && (
          <><a href={`/category/${post.categories[0].slug}/`}>{post.categories[0].title}</a> / </>
        )}
        <span>{post.title.slice(0, 60)}{post.title.length > 60 ? '…' : ''}</span>
      </div>
    </div>
  </div>

  <div class="container post-layout">
    <article class="post-main">
      {post.featuredImage?.asset && (
        <div class="post-hero-image">
          <img
            src={featuredImageUrl}
            alt={post.featuredImage.alt || post.title}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      )}

      <header class="post-header">
        <div class="post-meta">
          <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
          {post.categories.length > 0 && (
            <span class="post-meta__cats">
              {post.categories.map((cat: any) => (
                <a href={`/category/${cat.slug}/`} class="cat-tag">{cat.title}</a>
              ))}
            </span>
          )}
        </div>
        <h1 class="post-title">{post.title}</h1>
      </header>

      <div class="prose">
        <PortableText value={post.body} components={{ type: { image: PortableTextImage } }} />
      </div>

      {post.tags.length > 0 && (
        <div class="post-tags">
          <strong>Tags:</strong>
          {post.tags.map((tag: any) => (
            <span class="tag-label">{tag.title}</span>
          ))}
        </div>
      )}
    </article>

    <aside class="post-sidebar">
      <div class="sidebar-widget">
        <h3>Categories</h3>
        <div class="sidebar-cats">
          {post.categories.map((cat: any) => (
            <a href={`/category/${cat.slug}/`} class="cat-tag">{cat.title}</a>
          ))}
        </div>
      </div>
    </aside>
  </div>
</PageLayout>

<style>
  .post-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    padding-top: 2rem;
    padding-bottom: 3rem;
    align-items: start;
  }

  .post-hero-image {
    margin-bottom: 1.5rem;
    border-radius: var(--radius);
    overflow: hidden;
  }
  .post-hero-image img { width: 100%; height: auto; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .post-meta__cats { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  .post-title {
    font-size: 2rem;
    color: var(--color-navy);
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .post-tags {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .tag-label {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius);
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .post-sidebar { position: sticky; top: 1rem; }
  .sidebar-widget {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .sidebar-widget h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }
  .sidebar-cats { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  @media (max-width: 900px) {
    .post-layout { grid-template-columns: 1fr; }
    .post-sidebar { position: static; }
  }
</style>
