---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-HK', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<PageLayout
  title={post.data.title}
  description={post.data.description || post.data.excerpt}
  image={post.data.featuredImage}
  lang={post.data.lang === 'zh-Hant' ? 'zh-Hant' : post.data.lang === 'en' ? 'en' : 'zh-Hant'}
>
  <div class="page-banner">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> /
        {post.data.categories[0] && <><a href={`/category/${post.data.categories[0]}/`}>{post.data.categories[0].replace(/-/g, ' ')}</a> / </>}
        <span>{post.data.title.slice(0, 60)}{post.data.title.length > 60 ? '…' : ''}</span>
      </div>
    </div>
  </div>

  <div class="container post-layout">
    <article class="post-main">
      {post.data.featuredImage && (
        <div class="post-hero-image">
          <img src={post.data.featuredImage} alt={post.data.featuredImageAlt || post.data.title} />
        </div>
      )}

      <header class="post-header">
        <div class="post-meta">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          {post.data.categories.length > 0 && (
            <span class="post-meta__cats">
              {post.data.categories.map(cat => (
                <a href={`/category/${cat}/`} class="cat-tag">{cat.replace(/-/g, ' ')}</a>
              ))}
            </span>
          )}
        </div>
        <h1 class="post-title">{post.data.title}</h1>
      </header>

      <div class="prose">
        <Content />
      </div>

      {post.data.tags.length > 0 && (
        <div class="post-tags">
          <strong>Tags:</strong>
          {post.data.tags.map(tag => (
            <span class="tag-label">{tag.replace(/-/g, ' ')}</span>
          ))}
        </div>
      )}
    </article>

    <aside class="post-sidebar">
      <div class="sidebar-widget">
        <h3>Categories</h3>
        <ul>
          {post.data.categories.map(cat => (
            <li><a href={`/category/${cat}/`}>{cat.replace(/-/g, ' ')}</a></li>
          ))}
        </ul>
      </div>
    </aside>
  </div>
</PageLayout>

<style>
  .post-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    padding-top: 2rem;
    padding-bottom: 3rem;
    align-items: start;
  }

  .post-hero-image {
    margin-bottom: 1.5rem;
    border-radius: var(--radius);
    overflow: hidden;
  }
  .post-hero-image img { width: 100%; height: auto; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .post-meta__cats { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  .post-title {
    font-size: 2rem;
    color: var(--color-navy);
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .post-tags {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .tag-label {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius);
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .post-sidebar { position: sticky; top: 1rem; }
  .sidebar-widget {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .sidebar-widget h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }
  .sidebar-widget ul { list-style: none; padding: 0; }
  .sidebar-widget li { padding: 0.25rem 0; border-bottom: 1px solid var(--color-border); }
  .sidebar-widget li:last-child { border-bottom: none; }
  .sidebar-widget a { font-size: 0.9rem; color: var(--color-navy); }
  .sidebar-widget a:hover { color: var(--color-teal); }

  @media (max-width: 900px) {
    .post-layout { grid-template-columns: 1fr; }
    .post-sidebar { position: static; }
  }
</style>
