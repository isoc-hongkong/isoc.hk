---
import { sanityClient } from 'sanity:client';
import PageLayout from '../../layouts/PageLayout.astro';
import { urlFor, ALL_POSTS_QUERY } from '../../utils/sanity';

const posts = await sanityClient.fetch(ALL_POSTS_QUERY);

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-HK', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<PageLayout title="News" description="Latest news and updates from Internet Society Hong Kong.">
  <div class="page-banner">
    <div class="container">
      <h1>News</h1>
      <div class="breadcrumb"><a href="/">Home</a> / News</div>
    </div>
  </div>

  <div class="container" style="padding-bottom: 3rem;">
    <div class="post-grid">
      {posts.map((post: any) => (
        <article class="post-card">
          {post.featuredImage?.asset && (
            <div class="post-card__image">
              <img
                src={urlFor(post.featuredImage).width(600).url()}
                alt={post.featuredImage.alt || post.title}
                loading="lazy"
                decoding="async"
              />
            </div>
          )}
          <div class="post-card__body">
            <div class="post-card__meta">{formatDate(post.publishedAt)}</div>
            <h2 class="post-card__title">
              <a href={`/news/${post.slug}/`}>{post.title}</a>
            </h2>
            {post.excerpt && (
              <p class="post-card__excerpt">{post.excerpt.slice(0, 120)}{post.excerpt.length > 120 ? '…' : ''}</p>
            )}
            <div class="post-card__cats">
              {post.categories.slice(0, 2).map((cat: any) => (
                <a href={`/category/${cat.slug}/`} class="cat-tag">{cat.title}</a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</PageLayout>
