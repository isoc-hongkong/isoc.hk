---
import { sanityClient } from 'sanity:client';
import { SITE_SETTINGS_QUERY } from '../utils/sanity';

export interface Props {
  planId: string;
  label: string;
  successUrl: string;
  cancelUrl: string;
  publishableKey?: string;
}

const settings = await sanityClient.fetch(SITE_SETTINGS_QUERY);

const {
  planId,
  label,
  successUrl,
  cancelUrl,
  publishableKey = settings?.stripePublishableKey ?? 'pk_live_IWNPoLBAIJfzGUOXyDE5Hsx700B43hojZf',
} = Astro.props;

const buttonId = `checkout-button-${planId}`;
const errorId = `error-message-${planId}`;
---

<script is:inline src="https://js.stripe.com/v3"></script>
<p class="stripe-checkout">
  <button id={buttonId} class="stripe-checkout__button" type="button">{label}</button>
</p>
<div id={errorId} class="stripe-checkout__error" role="alert" aria-live="polite"></div>

<script
  is:inline
  define:vars={{ buttonId, errorId, planId, successUrl, cancelUrl, publishableKey }}
>
  (function () {
    var stripe = Stripe(publishableKey);
    var button = document.getElementById(buttonId);
    var errorEl = document.getElementById(errorId);
    if (!button) return;
    button.addEventListener('click', function () {
      stripe
        .redirectToCheckout({
          items: [{ plan: planId, quantity: 1 }],
          successUrl: successUrl,
          cancelUrl: cancelUrl,
        })
        .then(function (result) {
          if (result && result.error && errorEl) {
            errorEl.textContent = result.error.message;
          }
        });
    });
  })();
</script>

<style>
  .stripe-checkout {
    margin: 1.5rem 0;
  }
  .stripe-checkout__button {
    background-color: #6772e5;
    color: #fff;
    padding: 10px 18px;
    border: 0;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
  }
  .stripe-checkout__button:hover {
    background-color: #5469d4;
  }
  .stripe-checkout__error {
    color: #c0392b;
    margin-top: 0.5rem;
    min-height: 1.25rem;
  }
</style>
