---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/about/', label: 'About', key: 'about' },
  { href: '/category/news/', label: 'News', key: 'news' },
  { href: '/category/events/', label: 'Events', key: 'events' },
  { href: '/be-our-members/', label: 'Join Us', key: 'join' },
  { href: '/contact/', label: 'Contact', key: 'contact' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class:list={['site-header', { 'site-header--transparent': transparent }]}>
  <nav class="main-nav" aria-label="Main navigation">
    <div class="nav-inner container">
      <a class="nav-logo" href="/" aria-label="Internet Society Hong Kong — home">
        <img
          src="/images/ui/ISOC-HONG-KONG-Logo-Dark-Core-RGB-small.webp"
          alt="Internet Society Hong Kong"
          width="180"
          height="60"
          fetchpriority="high"
          loading="eager"
        />
      </a>

      <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="navMenu" aria-label="Toggle navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-menu" id="navMenu" role="list">
        {navLinks.map(({ href, label, key }) => (
          <li class={`nav-item nav-item--${key}`}>
            <a
              href={href}
              class:list={['nav-link', { 'nav-link--active': isActive(href) }]}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('navMenu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('nav-menu--open');
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>

<style>
  .site-header {
    background-image: url('/images/ui/header-isoc.webp');
    background-size: cover;
    background-position: center top;
  }
  .site-header--transparent {
    background-image: none;
  }

  .main-nav {
    /* transparent — colored cells sit directly over the header bg */
  }

  .nav-inner {
    display: flex;
    align-items: stretch;
    min-height: 60px;
    flex-wrap: wrap;
  }

  /* White logo cell */
  .nav-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    background: #fff;
    padding: 8px 16px;
    text-decoration: none;
  }
  .nav-logo img { height: 44px; width: auto; }

  /* Burger (mobile only) */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: rgba(255,255,255,0.15);
    border: none;
    cursor: pointer;
    padding: 0.5rem 0.75rem;
    margin-left: auto;
  }
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: white;
    transition: transform 0.2s;
  }

  /* Menu list */
  .nav-menu {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .nav-item {
    display: flex;
    flex: 1 1 auto;
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0 1rem;
    font-size: 0.95rem;
    font-weight: 500;
    text-align: center;
    white-space: nowrap;
    text-decoration: none;
    transition: background-color 0.15s;
  }

  /* Active page underline indicator */
  .nav-link--active {
    position: relative;
  }
  .nav-link--active::after {
    content: "";
    display: block;
    position: absolute;
    bottom: 4px;
    left: 5%;
    width: 90%;
    height: 2px;
    background: rgba(255,255,255,0.85);
  }

  /* Per-item colors (live site values, verified via DevTools) */
  .nav-item--about  .nav-link { background: #0c1c2c; color: #fff; }
  .nav-item--about  .nav-link:hover,
  .nav-item--about  .nav-link.nav-link--active { background: #173654; }

  .nav-item--news   .nav-link { background: #40b2a4; color: #0c1c2c; }
  .nav-item--news   .nav-link:hover,
  .nav-item--news   .nav-link.nav-link--active { background: #5fc6b9; }

  .nav-item--events .nav-link { background: #7e245c; color: #fff; }
  .nav-item--events .nav-link:hover,
  .nav-item--events .nav-link.nav-link--active { background: #a62f79; }

  .nav-item--join   .nav-link { background: #eeca4a; color: #0c1c2c; }
  .nav-item--join   .nav-link:hover,
  .nav-item--join   .nav-link.nav-link--active { background: #f2d879; }

  .nav-item--contact .nav-link { background: #0c2e48; color: #fff; }
  .nav-item--contact .nav-link:hover,
  .nav-item--contact .nav-link.nav-link--active { background: #0a2035; }

  /* Active state: the ::after indicator uses a dark line on the light-bg cells */
  .nav-item--news .nav-link--active::after,
  .nav-item--join .nav-link--active::after {
    background: rgba(12, 28, 44, 0.5);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .nav-menu {
      display: none;
      flex-direction: column;
      width: 100%;
    }
    .nav-menu--open { display: flex; }
    .nav-item { flex: none; }
    .nav-link {
      justify-content: flex-start;
      padding: 0.7rem 1.25rem;
    }
    .nav-inner { align-items: flex-start; padding-top: 0.25rem; padding-bottom: 0.25rem; }
  }
</style>
