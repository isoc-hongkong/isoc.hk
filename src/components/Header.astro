---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/about/', label: 'About', key: 'about' },
  { href: '/category/news/', label: 'News', key: 'news' },
  { href: '/category/events/', label: 'Events', key: 'events' },
  { href: '/be-our-members/', label: 'Join Us', key: 'join' },
  { href: '/contact/', label: 'Contact', key: 'contact' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class:list={['site-header', { 'site-header--transparent': transparent }]}>
  <nav class="main-nav" aria-label="Main navigation">
    <div class="nav-inner container">
      <a class="nav-logo" href="/" aria-label="Internet Society Hong Kong — home">
        <img
          src="/images/ui/ISOC-HONG-KONG-Logo-Dark-Core-RGB-small.webp"
          alt="Internet Society Hong Kong"
          width="180"
          height="60"
          fetchpriority="high"
          loading="eager"
        />
      </a>

      <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="navMenu" aria-label="Toggle navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-menu" id="navMenu" role="list">
        {navLinks.map(({ href, label, key }) => (
          <li class={`nav-item nav-item--${key}`}>
            <a
              href={href}
              class:list={['nav-link', { 'nav-link--active': isActive(href) }]}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('navToggle') as HTMLButtonElement | null;
  const menu = document.getElementById('navMenu');

  const header = document.querySelector<HTMLElement>('.site-header');

  function openMenu() {
    menu?.classList.add('nav-menu--open');
    toggle?.classList.add('nav-toggle--open');
    header?.classList.add('site-header--nav-open');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.classList.add('nav-open');
    const firstLink = menu?.querySelector<HTMLElement>('.nav-link');
    firstLink?.focus();
  }

  function closeMenu() {
    menu?.classList.remove('nav-menu--open');
    toggle?.classList.remove('nav-toggle--open');
    header?.classList.remove('site-header--nav-open');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('nav-open');
    toggle?.focus();
  }

  toggle?.addEventListener('click', () => {
    menu?.classList.contains('nav-menu--open') ? closeMenu() : openMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('nav-menu--open')) closeMenu();
  });

  menu?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('.nav-link')) closeMenu();
  });
</script>

<style>
  .site-header {
    position: relative;
    z-index: 200;
    background-image: url('/images/ui/header-isoc.webp');
    background-size: cover;
    background-position: center top;
  }
  .site-header--transparent {
    background-image: none;
  }

  .nav-inner {
    display: flex;
    align-items: stretch;
    min-height: 60px;
    flex-wrap: wrap;
  }

  /* White logo cell */
  .nav-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    background: #fff;
    padding: 8px 16px;
    text-decoration: none;
  }
  .nav-logo img { height: 44px; width: auto; }

  /* Burger (mobile only) */
  .nav-toggle {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: var(--color-teal-light);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    margin-left: auto;
    align-self: center;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-navy);
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.15s, background 0.2s;
  }

  /* X morph when open */
  .nav-toggle--open {
    background: #fff;
  }
  .nav-toggle--open span {
    background: var(--color-navy);
  }
  .nav-toggle--open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle--open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-toggle--open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Body scroll lock when nav drawer is open */
  :global(body.nav-open) {
    overflow: hidden;
  }

  /* Menu list */
  .nav-menu {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .nav-item {
    display: flex;
    flex: 1 1 auto;
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0 1rem;
    font-size: 0.95rem;
    font-weight: 500;
    text-align: center;
    white-space: nowrap;
    text-decoration: none;
    transition: background-color 0.15s;
  }

  /* Active page underline indicator */
  .nav-link--active {
    position: relative;
  }
  .nav-link--active::after {
    content: "";
    display: block;
    position: absolute;
    bottom: 4px;
    left: 5%;
    width: 90%;
    height: 2px;
    background: rgba(255,255,255,0.85);
  }

  /* Per-item colors (live site values, verified via DevTools) */
  .nav-item--about  .nav-link { background: #0c1c2c; color: #fff; }
  .nav-item--about  .nav-link:hover,
  .nav-item--about  .nav-link.nav-link--active { background: #173654; }

  .nav-item--news   .nav-link { background: #40b2a4; color: #0c1c2c; }
  .nav-item--news   .nav-link:hover,
  .nav-item--news   .nav-link.nav-link--active { background: #5fc6b9; }

  .nav-item--events .nav-link { background: #7e245c; color: #fff; }
  .nav-item--events .nav-link:hover,
  .nav-item--events .nav-link.nav-link--active { background: #a62f79; }

  .nav-item--join   .nav-link { background: #eeca4a; color: #0c1c2c; }
  .nav-item--join   .nav-link:hover,
  .nav-item--join   .nav-link.nav-link--active { background: #f2d879; }

  .nav-item--contact .nav-link { background: #0c2e48; color: #fff; }
  .nav-item--contact .nav-link:hover,
  .nav-item--contact .nav-link.nav-link--active { background: #0a2035; }

  /* Active state: dark indicator on light-bg cells */
  .nav-item--news .nav-link--active::after,
  .nav-item--join .nav-link--active::after {
    background: rgba(12, 28, 44, 0.5);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-toggle { display: flex; }

    .site-header {
      background-image: none;
      background-color: #fff;
    }

    .nav-inner {
      align-items: center;
      flex-wrap: nowrap;
    }

    /* Shift logo image slightly lower within the bar (same total height → drawer top unchanged) */
    .nav-logo {
      padding-top: 12px;
      padding-bottom: 4px;
    }

    /* Full-screen drawer overlay */
    .nav-menu {
      position: fixed;
      top: 60px;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 100;
      flex-direction: column;
      background: var(--color-navy);
      overflow-y: auto;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-8px);
      transition: opacity 180ms ease-out, transform 180ms ease-out;
    }
    .nav-menu--open {
      opacity: 1;
      pointer-events: auto;
      transform: none;
    }

    .nav-item { flex: none; }

    .nav-link {
      justify-content: flex-start;
      padding: 1rem 1.5rem;
      font-size: 1.05rem;
      white-space: normal;
    }

    /* Slightly taller active indicator on mobile */
    .nav-link--active::after {
      bottom: 6px;
    }
  }
</style>
